{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "rootDir": ".",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "types": ["node"]
  },
  "include": ["pi-extensions/**/*.ts"],
  "exclude": ["**/node_modules/**", "**/dist/**", "**/coverage/**"]
}
